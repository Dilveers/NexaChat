rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function isChatMemberByData(data) {
      return signedIn()
        && data.participants is list
        && uid() in data.participants;
    }

    function isGroupMemberByData(data) {
      return signedIn()
        && data.members is list
        && uid() in data.members;
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function groupPath(groupId) {
      return /databases/$(database)/documents/groups/$(groupId);
    }

    function isChatMember(chatId) {
      return signedIn()
        && exists(chatPath(chatId))
        && isChatMemberByData(get(chatPath(chatId)).data);
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(groupPath(groupId))
        && isGroupMemberByData(get(groupPath(groupId)).data);
    }

    function isGroupAdmin(groupId) {
      return signedIn()
        && exists(groupPath(groupId))
        && get(groupPath(groupId)).data.adminId == uid();
    }

    function hasValidMessageContent(data) {
      return (
        data.text is string
        && data.text.size() > 0
        && data.text.size() <= 1000
      )
      || data.image is string
      || data.fileUrl is string
      || data.audio is string;
    }

    function validUserScopedCreate(fieldName) {
      return signedIn() && request.resource.data[fieldName] == uid();
    }

    function validUserScopedRead(fieldName) {
      return signedIn() && resource.data[fieldName] == uid();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId) && request.resource.data.uid == uid();
      allow update: if isSelf(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if false;
    }

    match /presence/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isSelf(userId);
    }

    match /friends/{friendId} {
      allow read, delete: if signedIn() && uid() in resource.data.users;
      allow create: if signedIn()
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && uid() in request.resource.data.users;
      allow update: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (uid() == resource.data.fromUserId || uid() == resource.data.toUserId);
      allow create: if signedIn()
        && request.resource.data.fromUserId == uid()
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != uid()
        && request.resource.data.status == "pending";
      allow update: if signedIn()
        && uid() == resource.data.toUserId
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId;
      allow delete: if signedIn()
        && (uid() == resource.data.fromUserId || uid() == resource.data.toUserId);
    }

    match /chats/{chatId} {
      allow read, update, delete: if isChatMemberByData(resource.data);
      allow create: if isChatMemberByData(request.resource.data)
        && request.resource.data.participants.size() == 2;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.senderId == uid()
          && hasValidMessageContent(request.resource.data);
        allow update: if isChatMember(chatId)
          && request.resource.data.senderId == resource.data.senderId;
        allow delete: if isChatMember(chatId) && resource.data.senderId == uid();
      }

      match /typing/{userId} {
        allow read: if isChatMember(chatId);
        allow create, update, delete: if isSelf(userId) && isChatMember(chatId);
      }
    }

    match /groups/{groupId} {
      allow read: if isGroupMemberByData(resource.data);
      allow create: if signedIn()
        && request.resource.data.adminId == uid()
        && isGroupMemberByData(request.resource.data)
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 60;
      allow update: if isGroupAdmin(groupId)
        || (
          isGroupMember(groupId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members"])
          && !(uid() in request.resource.data.members)
        );
      allow delete: if isGroupAdmin(groupId);

      match /messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.senderId == uid()
          && hasValidMessageContent(request.resource.data);
        allow update: if isGroupMember(groupId)
          && request.resource.data.senderId == resource.data.senderId;
        allow delete: if isGroupMember(groupId) && resource.data.senderId == uid();
      }

      match /typing/{userId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isSelf(userId) && isGroupMember(groupId);
      }
    }

    match /archivedChats/{docId} {
      allow create: if validUserScopedCreate("userId");
      allow read, update, delete: if validUserScopedRead("userId");
    }

    match /deletedChats/{docId} {
      allow create: if validUserScopedCreate("userId");
      allow read, update, delete: if validUserScopedRead("userId");
    }

    match /mutedChats/{docId} {
      allow create: if validUserScopedCreate("userId");
      allow read, update, delete: if validUserScopedRead("userId");
    }

    match /blockedUsers/{docId} {
      allow create: if validUserScopedCreate("blockedBy");
      allow read, update, delete: if validUserScopedRead("blockedBy");
    }

    match /notificationState/{docId} {
      allow create, read, update, delete: if validUserScopedCreate("userId")
        || validUserScopedRead("userId");
    }

    match /forwardQueue/{userId} {
      allow create, read, update, delete: if isSelf(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

